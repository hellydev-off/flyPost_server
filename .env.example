# App
PORT=3000
NODE_ENV=development

# Mock режим (true = все внешние API заменены заглушками)
MOCK_MODE=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flypost
DB_USER=postgres
DB_PASSWORD=postgres

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=flyPostBot

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Grok API — не нужен при MOCK_MODE=true
GROK_API_KEY=your_grok_api_key_here

# Redis — не нужен при MOCK_MODE=true
REDIS_URL=redis://localhost:6379
