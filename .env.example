# App
PORT=3000
NODE_ENV=development

# Mock режим (true = все внешние API заменены заглушками)
MOCK_MODE=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flypost
DB_USER=postgres
DB_PASSWORD=postgres

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=flyPostBot

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Grok API — не нужен при MOCK_MODE=true
GROK_API_KEY=your_grok_api_key_here

# Redis — не нужен при MOCK_MODE=true
REDIS_URL=redis://localhost:6379

# ЮKassa — не нужен при MOCK_MODE=true
# Магазин ID и секретный ключ из личного кабинета: https://yookassa.ru/my/shop-settings/integration
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY=your_secret_key_here

# URL фронтенда — куда редиректить пользователя после оплаты
FRONTEND_URL=http://localhost:5173

# Audit Bot — уведомления о новых пользователях и оплатах
AUDIT_BOT_TOKEN=your_audit_bot_token_here
AUDIT_CHAT_ID=your_telegram_chat_id_here
